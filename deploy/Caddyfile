# Flowboard Caddyfile — Cloudflare-fronted, Cloudflare SSL = Full
#
# Setup:
#   • Cloudflare proxies flow.runany.dev → <VPS_IP>:443 (HTTPS, Full mode)
#   • Cloudflare SSL/TLS mode = "Full" (accepts self-signed on origin)
#   • Caddy terminates TLS on :443 with self-signed cert (tls internal)
#   • Caddy also listens on :8080 (HTTP) for Apache vhost (path :80 → :8080)
#   • Agent WS server binds 0.0.0.0:9223 (configured in docker-compose)
#
# Routing:
#   • WS upgrade (Connection: Upgrade + Upgrade: websocket) → agent:9223
#   • Anything else → agent:8101

{
	email {$EMAIL:admin@example.com}
	admin off
}

# ── HTTPS on :443 — Cloudflare Full SSL → here ──────────────────────
https://{$DOMAIN:localhost}:443 {
	encode zstd gzip

	# Self-signed cert from Caddy's internal CA. Cloudflare Full mode
	# accepts self-signed (no public CA validation).
	tls internal

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options    "nosniff"
		X-Frame-Options           "DENY"
		Referrer-Policy           "strict-origin-when-cross-origin"
		-Server
	}

	@ws {
		header Connection *Upgrade*
		header Upgrade websocket
	}
	handle @ws {
		# Default transport (HTTP/1.1) — agent WS server doesn't speak h2.
		# Caddy auto-upgrades to WebSocket on 101 response.
		reverse_proxy agent:9223
	}

	handle {
		reverse_proxy agent:8101 {
			header_up Host {host}
			header_up X-Real-IP {remote_host}
		}
	}

	log {
		output stdout
		level INFO
	}
}

# ── HTTP on :8080 — used by Apache vhost ───────────────────────────
http://{$DOMAIN:localhost}:8080 {
	encode zstd gzip

	@ws {
		header Connection *Upgrade*
		header Upgrade websocket
	}
	handle @ws {
		reverse_proxy agent:9223
	}

	handle {
		reverse_proxy agent:8101 {
			header_up Host {host}
			header_up X-Real-IP {remote_host}
		}
	}

	log {
		output stdout
		level INFO
	}
}
