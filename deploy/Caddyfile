# Flowboard Caddyfile — HTTP-only origin, Cloudflare handles public TLS
#
# Setup:
#   • Cloudflare proxies flow.runany.dev → <VPS_IP>:8080 (plain HTTP)
#   • Cloudflare SSL/TLS mode = "Flexible"
#     (CF terminates TLS for end users, forwards plaintext to origin)
#   • Caddy listens on :8080 only — no cert, no ACME, no port 443 needed
#
# Trade-off: traffic between Cloudflare edge and origin is plaintext.
# For personal use this is fine — that segment traverses Cloudflare's
# backbone which is generally trusted. If you need CF→origin encryption,
# switch Cloudflare to "Full" mode and add a cert block to this file.

{
	email {$EMAIL:admin@example.com}
	admin off
}

http://{$DOMAIN:localhost}:8080 {
	encode zstd gzip

	# ── WebSocket matcher ─────────────────────────────────────
	@ws {
		header Connection *Upgrade*
		header Upgrade websocket
	}
	handle @ws {
		reverse_proxy agent:9223 {
			transport http {
				dial_timeout 10s
				response_header_timeout 0s
				read_timeout 0s
				write_timeout 0s
				versions h2c 1.1
			}
		}
	}

	# ── HTTP fallback ─────────────────────────────────────────
	handle {
		reverse_proxy agent:8101 {
			header_up Host {host}
			header_up X-Real-IP {remote_host}
		}
	}

	log {
		output stdout
		level INFO
	}
}
