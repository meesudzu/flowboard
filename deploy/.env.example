# Flowboard production env. Copy to .env and fill in.
#   cp .env.example .env && $EDITOR .env
#
# Simplest setup: Cloudflare in front, Caddy on :8080 (HTTP only).
#   • Cloudflare proxies flow.runany.dev → <VPS_IP>:8080 (plain HTTP)
#   • Cloudflare SSL/TLS mode = "Flexible"
#     (CF terminates TLS for end users; CF→origin is plaintext on
#      Cloudflare's backbone, which is generally trusted)
#   • Caddy listens on :8080 only — no 80/443, no cert, no ACME
#
# DOMAIN must resolve (A/AAAA) to your VPS's public IP. The orange-cloud
# proxy icon must be ON in Cloudflare DNS for this to work.
# EMAIL is sent to Let's Encrypt on cert issuance (only used if you
# later switch to Full/Strict mode with origin HTTPS).

FLOWBOARD_DOMAIN=flow.runany.dev
FLOWBOARD_EMAIL=you@example.com

# ── Optional ────────────────────────────────────────────────────────
# MiniMax (the agent's only LLM provider). You can also paste the key
# via the Settings UI after first deploy; this var just pre-seeds it.
MINIMAX_API_KEY=

# "real" → always call MiniMax
# "mock" → never call (offline dev)
# "auto" → call MiniMax if key is set, else mock
FLOWBOARD_PLANNER_BACKEND=real

# Pinned planner model (informational only; provider picks internally)
FLOWBOARD_PLANNER_MODEL=MiniMax-M2.7-highspeed

# ── Optional HTTP Basic auth ───────────────────────────────────────
# When BOTH are set (non-empty), the agent gates every request behind
# ``Authorization: Basic <user>:<password>``. The browser will pop its
# native auth dialog on first visit, and the dev/extension/local
# monitoring tools need to be configured with the same credentials
# (or hit one of the public paths below).
#
# Public paths (always bypass auth):
#   • /api/health         -- uptime monitors
#   • /api/ext/callback   -- the extension posts here with HMAC
#   • WebSocket upgrades  -- defence in depth
#
# Leave BOTH empty to disable auth entirely (default — keeps backward
# compatibility for existing single-user installs).
FLOWBOARD_BASIC_AUTH_USER=
FLOWBOARD_BASIC_AUTH_PASSWORD=
