#!/usr/bin/env bash
# Flowboard background-service control script (macOS launchd).
#
# Usage:  flowboard {install|dev|start|stop|restart|status|logs|build|uninstall}
#
#   install    create venv on the system disk, install deps, build FE,
#              generate plist with correct paths, then load the LaunchAgent
#   dev        foreground mode with --reload (auto-restart on .py edits)
#              Ctrl+C exits dev AND re-loads the service automatically
#   start      load + run  (background)
#   stop       unload
#   restart    unload + load
#   status     show whether the service is running + last 5 log lines
#   logs       tail -f both stdout and stderr
#   build      rebuild frontend (run after editing React code)
#   uninstall  stop and remove the plist
set -euo pipefail

LABEL="com.flowboard.agent"

# Derive PROJECT from the script's own location so the CLI works no
# matter where the repo is cloned. Follows symlinks (so `flowboard`
# on PATH or an alias in ~/bin both resolve to the real bin/ dir).
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
PROJECT="$(cd -P "$SCRIPT_DIR/.." && pwd)"

# Sanity check: refuse to run if the resolved path doesn't look like a
# flowboard checkout. Catches "moved the script without updating
# symlinks" / "ran from a stale copy in /tmp" before we silently do
# the wrong thing to a different directory tree.
for _fb_required in bin agent frontend scripts; do
  [ -d "$PROJECT/$_fb_required" ] || {
    echo "fatal: $PROJECT is not a flowboard project (missing $_fb_required/)" >&2
    exit 1
  }
done
unset _fb_required

PLIST_SRC="$PROJECT/scripts/${LABEL}.plist"
PLIST_DST="$HOME/Library/LaunchAgents/${LABEL}.plist"
LOG_DIR="$HOME/.flowboard/logs"
# Venv lives on the SYSTEM disk (not inside the project tree). launchd's
# sandbox can read existing files anywhere, but a freshly created .venv on
# an external volume (/Volumes/...) is hit with EPERM during the very first
# site-module bootstrap, so the venv python dies before uvicorn starts.
# Keeping it under $HOME on the boot volume sidesteps the rule entirely.
VENV_DIR="$HOME/.flowboard/agent-venv"
HAS_UV="$(command -v uv 2>/dev/null || true)"

red()   { printf "\033[31m%s\033[0m\n" "$*"; }
green() { printf "\033[32m%s\033[0m\n" "$*"; }
blue()  { printf "\033[34m%s\033[0m\n" "$*"; }

is_loaded() {
  launchctl list 2>/dev/null | grep -q "$LABEL"
}

# Create the venv at $VENV_DIR and install project deps (editable + dev
# extras). Idempotent: skips venv creation if it already exists; the pip
# install always runs so adding/removing deps in pyproject.toml is picked up.
create_venv() {
  mkdir -p "$(dirname "$VENV_DIR")"
  if [ ! -x "$VENV_DIR/bin/python" ]; then
    blue "→ creating venv at $VENV_DIR"
    if [ -n "$HAS_UV" ]; then
      (cd "$PROJECT/agent" && uv venv "$VENV_DIR")
    else
      python3 -m venv "$VENV_DIR"
    fi
  else
    blue "→ venv already exists at $VENV_DIR (skipping create)"
  fi
  blue "→ installing project deps (editable, with dev extras)"
  if [ -n "$HAS_UV" ]; then
    (cd "$PROJECT/agent" && uv pip install --python "$VENV_DIR/bin/python" -e ".[dev]")
  else
    (cd "$PROJECT/agent" && "$VENV_DIR/bin/pip" install -e ".[dev]")
  fi
}

# Generate the LaunchAgent plist by substituting __VENV_PATH__ and
# __WORKDIR__ placeholders in the template. The template in scripts/ stays
# pristine; only the per-user copy in ~/Library/LaunchAgents/ gets the
# actual paths. Re-running install is safe — it just overwrites the copy.
generate_plist() {
  mkdir -p "$(dirname "$PLIST_DST")"
  # Substitute __VENV_PATH__ / __WORKDIR__ in the XML template, then convert
  # to binary1 before install. launchd in this env returns EIO on xml1 plists
  # (seen on fresh install with the templated multi-line format), and binary1
  # is faster to parse anyway.
  sed -e "s|__VENV_PATH__|$VENV_DIR|g" \
      -e "s|__WORKDIR__|$PROJECT/agent|g" \
      "$PLIST_SRC" \
    | plutil -convert binary1 -o "$PLIST_DST" -
}

cmd="${1:-help}"
case "$cmd" in
  install)
    [ -f "$PLIST_SRC" ] || { red "missing $PLIST_SRC"; exit 1; }
    mkdir -p "$LOG_DIR"

    create_venv

    # Build frontend if dist/ is missing (first install or after fresh clone).
    if [ ! -d "$PROJECT/frontend/dist" ]; then
      blue "→ building frontend (first install)…"
      (cd "$PROJECT/frontend" && npm run build)
    fi

    # If the user previously installed but moved/recreated the project, the
    # hash of the binary path may have changed — unload first to be safe.
    if is_loaded; then
      launchctl unload "$PLIST_DST" 2>/dev/null || true
    fi

    generate_plist
    launchctl load -w "$PLIST_DST"
    green "✓ installed and started"
    blue  "  → http://localhost:8101"
    blue  "  → venv: $VENV_DIR"
    blue  "  → logs: $LOG_DIR"
    blue  "  → flowboard status / logs / stop"
    ;;

  start)
    if is_loaded; then blue "already loaded"; else launchctl load -w "$PLIST_DST"; green "✓ started"; fi
    ;;

  stop)
    if is_loaded; then launchctl unload "$PLIST_DST"; green "✓ stopped"; else blue "not running"; fi
    ;;

  restart)
    launchctl unload "$PLIST_DST" 2>/dev/null || true
    launchctl load -w "$PLIST_DST"
    green "✓ restarted"
    ;;

  status)
    if is_loaded; then
      green "● running"
      launchctl list | grep "$LABEL" || true
      echo
      blue "tail (out):"; tail -n 5 "$LOG_DIR/agent.out.log" 2>/dev/null || echo "  (no logs yet)"
      blue "tail (err):"; tail -n 5 "$LOG_DIR/agent.err.log" 2>/dev/null || echo "  (no logs yet)"
    else
      red "○ not running"
    fi
    ;;

  logs)
    mkdir -p "$LOG_DIR"
    tail -n 50 -f "$LOG_DIR/agent.out.log" "$LOG_DIR/agent.err.log"
    ;;

  build)
    blue "→ rebuilding frontend…"
    (cd "$PROJECT/frontend" && npm run build)
    green "✓ built. restart the agent to pick up the new dist/: flowboard restart"
    ;;

  uninstall)
    launchctl unload "$PLIST_DST" 2>/dev/null || true
    rm -f "$PLIST_DST"
    green "✓ uninstalled"
    ;;

  dev)
    # Foreground mode for active development: --reload watches agent/flowboard
    # and restarts the worker on any .py change (~0.5s round-trip).
    # We temporarily unload the LaunchAgent to free :8101, and re-load it on
    # exit so the service is "always there" the moment you step away.
    [ -x "$VENV_DIR/bin/uvicorn" ] || {
      red "venv not found at $VENV_DIR — run: flowboard install"
      exit 1
    }
    if is_loaded; then
      blue "→ stopping service to free port 8101…"
      launchctl unload "$PLIST_DST" 2>/dev/null || true
      restart_on_exit=true
    else
      restart_on_exit=false
    fi

    cleanup() {
      echo
      if [ "$restart_on_exit" = true ]; then
        blue "→ restarting service…"
        if launchctl load -w "$PLIST_DST" 2>/dev/null; then
          green "✓ service back up"
        else
          red "✗ failed to restart service — run: flowboard start"
        fi
      fi
    }
    trap cleanup EXIT INT TERM

    blue "→ uvicorn --reload (Ctrl+C to stop dev + auto-restart service)"
    blue "  venv:    $VENV_DIR"
    blue "  watching: $PROJECT/agent/flowboard/**"
    blue "  ignoring: $VENV_DIR, __pycache__, ../storage"
    cd "$PROJECT/agent"
    exec "$VENV_DIR/bin/uvicorn" flowboard.main:app \
      --host 127.0.0.1 --port 8101 --reload \
      --reload-dir flowboard \
      --reload-exclude "$VENV_DIR" \
      --reload-exclude '__pycache__' \
      --reload-exclude '../storage'
    # exec replaces the shell, so cleanup() only runs on signal from outside
    # (which is exactly the Ctrl+C case we care about).
    ;;

  help)
    sed -n '2,15p' "$0" | sed 's/^# \{0,1\}//' | sed '/^$/d'
    ;;

  *)
    echo "unknown command: $1" >&2
    echo "run: flowboard help"
    exit 1
    ;;
esac
